APP_ENV=development
SITE_NAME=REMOVEBGKU
SITE_TAGLINE=Hapus latar belakang gambar dengan mudah
APP_BASE_URL=http://localhost:8000
APP_TIME_ZONE=Asia/Jakarta
APP_VERSION=dev
PORT=8000
DEBUG=true
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
ADMIN_URL_PATH=admin/
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
DATABASE_URL=postgresql://app:replace-me@postgres:5432/app
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-me
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
USE_REDIS_CACHE=true
CELERY_CONCURRENCY=1
CELERY_PREFETCH_MULTIPLIER=1
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_TASK_TIME_LIMIT=300
STORAGE_BACKEND=local
MEDIA_ROOT=/data/media
STORAGE_PREFIX=development
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto
AWS_QUERYSTRING_EXPIRE=300
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_ADDRESSING_STYLE=auto
AWS_DEFAULT_ACL=
AWS_S3_FILE_OVERWRITE=false
DEFAULT_REMBG_MODEL=u2netp
ALLOWED_REMBG_MODELS=u2netp,isnet-general-use
PRELOAD_MODELS=u2netp
MODEL_CACHE_DIR=/models
U2NET_HOME=/models
UPLOAD_MAX_BYTES=52428800
MAX_IMAGE_PIXELS=36000000
MAX_IMAGE_WIDTH=6000
MAX_IMAGE_HEIGHT=6000
MIN_IMAGE_WIDTH=32
MIN_IMAGE_HEIGHT=32
JOB_RETENTION_HOURS=24
METADATA_RETENTION_DAYS=30
CLEANUP_BATCH_SIZE=100
STALE_PROCESSING_MINUTES=10
UPLOAD_RATE_LIMIT_PER_HOUR=10
DOWNLOAD_RATE_LIMIT_PER_MINUTE=30
ADMIN_LOGIN_RATE_LIMIT_PER_15_MINUTES=10
MAX_ACTIVE_JOBS_PER_SESSION=3
MAX_QUEUE_SIZE=50
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
SESSION_HASH_SECRET=replace-with-independent-random-secret
IP_HASH_SECRET=replace-with-independent-random-secret
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-long-random-password
BOOTSTRAP_ADMIN_FULL_NAME=Administrator
FORCE_RESET_BOOTSTRAP_ADMIN_PASSWORD=false
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0
DOMAIN=localhost
CADDY_EMAIL=
APP_IMAGE=removebgku:local
