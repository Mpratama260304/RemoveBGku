# ============================================================
# REMOVEBGKU - deploy tanpa ribet
# ============================================================
# Untuk deploy standar kamu TIDAK butuh file .env sama sekali.
# Cukup jalankan di VPS:
#     docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# Semua secret (SECRET_KEY & password DB) dibuat otomatis dan disimpan
# di volume Docker (tidak masuk ke repo/image). Password admin awal
# ditampilkan sekali di log service "web":
#     docker compose logs web | grep -A3 "admin siap"
#
# ------------------------------------------------------------
# HANYA kalau pakai domain + HTTPS otomatis: set satu variabel ini.
# Bisa lewat `export DOMAIN=...` ATAU simpan file bernama `.env`
# (satu baris) di folder yang sama dengan docker-compose.
# ------------------------------------------------------------
DOMAIN=removebgku.example.com

# ------------------------------------------------------------
# Semua di bawah OPSIONAL - hapus tanda # untuk mengaktifkan.
# ------------------------------------------------------------
# APP_IMAGE=mpratama260304/removebgku:latest   # ganti image / tag
# APP_VERSION=1.0.0
# POSTGRES_PASSWORD=ganti-password-database-yang-kuat
# BOOTSTRAP_ADMIN_EMAIL=admin@removebgku.example.com
# BOOTSTRAP_ADMIN_PASSWORD=ganti-password-admin-yang-kuat
# DJANGO_SECRET_KEY=isi-manual-minimal-50-karakter-acak
# STRICT_ENV=true                              # paksa validasi env ketat
